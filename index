<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Book PC and console gaming sessions at Saguni Gaming Cafe.">
  <title>Saguni Gaming Cafe</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,400;0,600;0,700;0,800;1,700&family=Barlow+Condensed:wght@700;800;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #060608;
      --surface: #0e0e12;
      --surface2: #15151c;
      --gold: #f5c842;
      --gold2: #e8a820;
      --red: #e83232;
      --white: #f2f2f2;
      --muted: #8a8a9a;
      --line: rgba(255,255,255,0.08);
      --radius: 4px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-size: 16px;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }
    img { display: block; max-width: 100%; }

    /* ── TOPBAR ── */
    .topbar {
      background: #0a0a0e;
      border-bottom: 1px solid var(--line);
      padding: 0.5rem clamp(1rem,5vw,5rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.82rem;
      color: var(--muted);
      gap: 1rem;
    }
    .topbar a { color: var(--muted); transition: color 0.2s; }
    .topbar a:hover { color: var(--gold); }
    .topbar-left, .topbar-right { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }

    /* ── HEADER ── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(6,6,8,0.96);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 0 clamp(1rem,5vw,5rem);
      height: 72px;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .logo-icon {
      width: 44px;
      height: 44px;
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      border-radius: var(--radius);
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }
    .logo-icon svg { width: 26px; height: 26px; }
    .logo-text strong {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.35rem;
      letter-spacing: 2px;
      color: var(--white);
      line-height: 1;
    }
    .logo-text small {
      display: block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold);
      line-height: 1;
      margin-top: 2px;
    }
    .nav { display: flex; align-items: center; gap: 2rem; }
    .nav a {
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #ccc;
      transition: color 0.2s;
      position: relative;
    }
    .nav a::after {
      content: '';
      position: absolute;
      left: 0; bottom: -4px;
      width: 0; height: 2px;
      background: var(--gold);
      transition: width 0.2s;
    }
    .nav a:hover { color: var(--white); }
    .nav a:hover::after { width: 100%; }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.65rem 1.4rem;
      border-radius: var(--radius);
      font-weight: 800;
      font-size: 0.88rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn:active { transform: scale(0.97); }
    .btn-gold {
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      color: #0a0a0e;
    }
    .btn-gold:hover { box-shadow: 0 0 24px rgba(245,200,66,0.4); }
    .btn-outline {
      background: transparent;
      border: 2px solid var(--gold);
      color: var(--gold);
    }
    .btn-outline:hover { background: rgba(245,200,66,0.1); }
    .btn-red {
      background: linear-gradient(135deg, var(--red), #b02020);
      color: #fff;
    }
    .btn-red:hover { box-shadow: 0 0 24px rgba(232,50,50,0.4); }

    /* ── HERO SLIDER ── */
    .hero {
      position: relative;
      height: calc(100svh - 72px);
      min-height: 520px;
      overflow: hidden;
    }
    .slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 1s ease;
    }
    .slide.active { opacity: 1; }
    .slide img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.38) saturate(0.8);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(6,6,8,0.92) 0%, rgba(6,6,8,0.5) 55%, rgba(6,6,8,0.15) 100%),
                  linear-gradient(0deg, rgba(6,6,8,0.85) 0%, transparent 40%);
    }
    .hero-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 clamp(1.5rem,8vw,8rem);
      max-width: 900px;
    }
    .hero-kicker {
      display: inline-block;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 0.8rem;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(245,200,66,0.35);
      padding: 0.3rem 0.8rem;
      border-radius: 2px;
      margin-bottom: 1.2rem;
      width: fit-content;
    }
    .hero-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.5rem, 9vw, 8rem);
      line-height: 0.92;
      letter-spacing: 2px;
      color: var(--white);
      margin-bottom: 1.2rem;
    }
    .hero-title span { color: var(--gold); }
    .hero-desc {
      font-size: clamp(1rem, 1.6vw, 1.2rem);
      font-weight: 600;
      color: rgba(242,242,242,0.75);
      max-width: 520px;
      line-height: 1.65;
      margin-bottom: 2rem;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-dots {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 0.5rem;
      z-index: 2;
    }
    .hero-dots button {
      width: 28px; height: 4px;
      border: none;
      background: rgba(255,255,255,0.25);
      cursor: pointer;
      border-radius: 2px;
      transition: background 0.3s, width 0.3s;
    }
    .hero-dots button.active {
      background: var(--gold);
      width: 48px;
    }

    /* ── GAME MARQUEE ── */
    .marquee-strip {
      background: var(--gold);
      padding: 0.6rem 0;
      overflow: hidden;
      white-space: nowrap;
    }
    .marquee-inner {
      display: inline-flex;
      gap: 0;
      animation: marquee 22s linear infinite;
    }
    .marquee-inner span {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 3px;
      color: #0a0a0e;
      padding: 0 2rem;
    }
    .marquee-inner span.dot { color: #0a0a0e; padding: 0; }
    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ── SECTIONS ── */
    section { padding: clamp(3rem,7vw,6rem) clamp(1.5rem,5vw,5rem); }
    .section-kicker {
      display: inline-block;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 0.78rem;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }
    h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.4rem,5vw,4.2rem);
      line-height: 0.95;
      letter-spacing: 1px;
      margin-bottom: 1rem;
    }
    h2 span { color: var(--gold); }
    h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 1.15rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    p { color: var(--muted); line-height: 1.7; }

    /* ── STATS BAR ── */
    .stats-bar {
      background: var(--surface);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .stat-item {
      padding: 2rem 1rem;
      text-align: center;
      border-right: 1px solid var(--line);
      position: relative;
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.8rem,5vw,4rem);
      color: var(--gold);
      line-height: 1;
      display: block;
    }
    .stat-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.3rem;
    }

    /* ── ABOUT ── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem,5vw,5rem);
      align-items: center;
    }
    .about-img {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
    }
    .about-img img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      filter: saturate(0.8) contrast(1.1);
    }
    .about-img::before {
      content: '';
      position: absolute;
      inset: 0;
      border: 2px solid rgba(245,200,66,0.3);
      border-radius: var(--radius);
      z-index: 1;
      pointer-events: none;
    }
    .about-img::after {
      content: 'SAGUNI GAMING';
      position: absolute;
      bottom: 1rem; left: 1rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 4px;
      color: var(--gold);
      z-index: 2;
      background: rgba(6,6,8,0.75);
      padding: 0.3rem 0.6rem;
    }
    .about-content p { margin-bottom: 1.2rem; }
    .about-features {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .about-feat {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.88rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--white);
    }
    .about-feat::before {
      content: '';
      width: 8px; height: 8px;
      background: var(--gold);
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── STATIONS ── */
    .stations-bg {
      background: var(--surface);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .station-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .station-card {
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
      transition: transform 0.2s, border-color 0.2s;
      position: relative;
    }
    .station-card:hover {
      transform: translateY(-6px);
      border-color: rgba(245,200,66,0.5);
    }
    .station-card img {
      width: 100%;
      aspect-ratio: 16/10;
      object-fit: cover;
      filter: saturate(0.85);
    }
    .station-tag {
      position: absolute;
      top: 1rem; left: 1rem;
      background: var(--gold);
      color: #0a0a0e;
